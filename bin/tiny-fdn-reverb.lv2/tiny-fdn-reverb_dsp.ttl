@prefix doap:  <http://usefulinc.com/ns/doap#> .
@prefix foaf:  <http://xmlns.com/foaf/0.1/> .
@prefix lv2:   <http://lv2plug.in/ns/lv2core#> .
@prefix midi:  <http://lv2plug.in/ns/ext/midi#> .
@prefix mod:   <http://moddevices.com/ns/mod#> .
@prefix opts:  <http://lv2plug.in/ns/ext/options#> .
@prefix pg:    <http://lv2plug.in/ns/ext/port-groups#> .
@prefix patch: <http://lv2plug.in/ns/ext/patch#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix spdx:  <http://spdx.org/rdf/terms#> .
@prefix ui:    <http://lv2plug.in/ns/extensions/ui#> .
@prefix unit:  <http://lv2plug.in/ns/extensions/units#> .

<https://codeberg.org/fernandoAra/tiny-fdn-reverb#tiny-fdn-reverb>
    a lv2:AmplifierPlugin, lv2:Plugin, doap:Project ;

    lv2:extensionData opts:interface ,
                      <http://kxstudio.sf.net/ns/lv2ext/programs#Interface> ;

    lv2:optionalFeature <http://lv2plug.in/ns/lv2core#hardRTCapable> ,
                        <http://lv2plug.in/ns/ext/buf-size#boundedBlockLength> ;

    lv2:requiredFeature opts:options ,
                        <http://lv2plug.in/ns/ext/urid#map> ;

    opts:supportedOption <http://lv2plug.in/ns/ext/buf-size#nominalBlockLength> ,
                         <http://lv2plug.in/ns/ext/buf-size#maxBlockLength> ,
                         <http://lv2plug.in/ns/ext/parameters#sampleRate> ;

    ui:ui <https://codeberg.org/fernandoAra/tiny-fdn-reverb#tiny-fdn-reverb#DPF_UI> ;

    lv2:port [
        a lv2:InputPort, lv2:AudioPort ;
        lv2:index 0 ;
        lv2:symbol "lv2_audio_in_1" ;
        lv2:name "Audio Input 1" ;
    ] ,
    [
        a lv2:InputPort, lv2:AudioPort ;
        lv2:index 1 ;
        lv2:symbol "lv2_audio_in_2" ;
        lv2:name "Audio Input 2" ;
    ] ;

    lv2:port [
        a lv2:OutputPort, lv2:AudioPort ;
        lv2:index 2 ;
        lv2:symbol "lv2_audio_out_1" ;
        lv2:name "Audio Output 1" ;
    ] ,
    [
        a lv2:OutputPort, lv2:AudioPort ;
        lv2:index 3 ;
        lv2:symbol "lv2_audio_out_2" ;
        lv2:name "Audio Output 2" ;
    ] ;

    lv2:port [
        a lv2:InputPort, lv2:ControlPort ;
        lv2:index 4 ;
        lv2:name "RT60 (s)" ;
        lv2:symbol "rt60" ;
        lv2:default 0.20000000298 ;
        lv2:minimum 8 ;
        lv2:maximum 2.79999995232 ;
    ] ,
    [
        a lv2:InputPort, lv2:ControlPort ;
        lv2:index 5 ;
        lv2:name "Mix" ;
        lv2:symbol "mix" ;
        lv2:default 0 ;
        lv2:minimum 1 ;
        lv2:maximum 1 ;
    ] ,
    [
        a lv2:InputPort, lv2:ControlPort ;
        lv2:index 6 ;
        lv2:name "MatrixType" ;
        lv2:symbol "matrix" ;
        lv2:default 0 ;
        lv2:minimum 1 ;
        lv2:maximum 0 ;
        lv2:portProperty lv2:integer ;
    ] ,
    [
        a lv2:InputPort, lv2:ControlPort ;
        lv2:index 7 ;
        lv2:name "DelaySet" ;
        lv2:symbol "delayset" ;
        lv2:default 0 ;
        lv2:minimum 1 ;
        lv2:maximum 0 ;
        lv2:portProperty lv2:integer ;
    ] ,
    [
        a lv2:InputPort, lv2:ControlPort ;
        lv2:index 8 ;
        lv2:name "Size" ;
        lv2:symbol "size" ;
        lv2:default 0.5 ;
        lv2:minimum 2 ;
        lv2:maximum 1 ;
    ] ,
    [
        a lv2:InputPort, lv2:ControlPort ;
        lv2:index 9 ;
        lv2:name "Damp (Hz)" ;
        lv2:symbol "damp" ;
        lv2:default 1500 ;
        lv2:minimum 12000 ;
        lv2:maximum 6000 ;
        unit:unit unit:hz ;
    ] ,
    [
        a lv2:InputPort, lv2:ControlPort ;
        lv2:index 10 ;
        lv2:name "Matrix Morph" ;
        lv2:symbol "mmorph" ;
        lv2:default 0 ;
        lv2:minimum 1 ;
        lv2:maximum 0 ;
    ] ,
    [
        a lv2:InputPort, lv2:ControlPort ;
        lv2:index 11 ;
        lv2:name "Ping" ;
        lv2:symbol "ping" ;
        lv2:default 0 ;
        lv2:minimum 1 ;
        lv2:maximum 0 ;
        lv2:portProperty lv2:toggled ;
    ] ,
    [
        a lv2:InputPort, lv2:ControlPort ;
        lv2:index 12 ;
        lv2:name "Mod Depth" ;
        lv2:symbol "moddepth" ;
        lv2:default 0 ;
        lv2:minimum 1 ;
        lv2:maximum 0 ;
    ] ,
    [
        a lv2:InputPort, lv2:ControlPort ;
        lv2:index 13 ;
        lv2:name "Detune" ;
        lv2:symbol "detune" ;
        lv2:default 0 ;
        lv2:minimum 1 ;
        lv2:maximum 0 ;
    ] ,
    [
        a lv2:InputPort, lv2:ControlPort ;
        lv2:index 14 ;
        lv2:name "Over-spread delays" ;
        lv2:symbol "metal" ;
        lv2:default 0 ;
        lv2:minimum 1 ;
        lv2:maximum 0 ;
        lv2:portProperty lv2:toggled ;
    ] ,
    [
        a lv2:InputPort, lv2:ControlPort ;
        lv2:index 15 ;
        lv2:name "Noise Burst" ;
        lv2:symbol "burst" ;
        lv2:default 0 ;
        lv2:minimum 1 ;
        lv2:maximum 0 ;
        lv2:portProperty lv2:toggled ;
    ] ,
    [
        a lv2:OutputPort, lv2:ControlPort ;
        lv2:index 16 ;
        lv2:name "EDT" ;
        lv2:symbol "edt" ;
        lv2:minimum 4000 ;
        lv2:maximum 0 ;
        unit:unit unit:ms ;
    ] ,
    [
        a lv2:OutputPort, lv2:ControlPort ;
        lv2:index 17 ;
        lv2:name "RT60(est)" ;
        lv2:symbol "rt60est" ;
        lv2:minimum 10 ;
        lv2:maximum 0 ;
        unit:unit unit:s ;
    ] ,
    [
        a lv2:OutputPort, lv2:ControlPort ;
        lv2:index 18 ;
        lv2:name "Density@100ms" ;
        lv2:symbol "dens100" ;
        lv2:minimum 50 ;
        lv2:maximum 0 ;
        unit:unit [
            a unit:Unit ;
            rdfs:label  "ev/ms" ;
            unit:symbol "ev/ms" ;
            unit:render "%f ev/ms" ;
        ] ;
    ] ,
    [
        a lv2:OutputPort, lv2:ControlPort ;
        lv2:index 19 ;
        lv2:name "Density@300ms" ;
        lv2:symbol "dens300" ;
        lv2:minimum 50 ;
        lv2:maximum 0 ;
        unit:unit [
            a unit:Unit ;
            rdfs:label  "ev/ms" ;
            unit:symbol "ev/ms" ;
            unit:render "%f ev/ms" ;
        ] ;
    ] ,
    [
        a lv2:OutputPort, lv2:ControlPort ;
        lv2:index 20 ;
        lv2:name "Ringiness" ;
        lv2:symbol "ring" ;
        lv2:minimum 1 ;
        lv2:maximum 0 ;
    ] ;

    mod:brand "N/A" ;
    mod:label "tiny-fdn-reverb" ;

    doap:name "tiny-fdn-reverb" ;
    doap:license <http://spdx.org/licenses/MIT.html> ;

    doap:maintainer [
        foaf:name "Fernando Ara" ;
    ] ;

    lv2:microVersion 1 ;
    lv2:minorVersion 3 .
